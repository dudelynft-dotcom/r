# ── dependencies ──────────────────────────────
node_modules/

# ── next.js ───────────────────────────────────
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ── env & secrets (NEVER commit) ──────────────
.env
.env.local
.env*.local
*.pem

# ── python ────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# ── large / generated art (regenerable) ───────
art-pipeline/**/output/
art-previews/
runpod/**/output/
snapshot/output/
# NOTE: web/data/snapshot.json IS committed (the site needs it) — not ignored.

# ── heavy binaries / archives ─────────────────
*.zip
*.safetensors
*.ckpt
*.pt
*.pth
*.mp4

# ── os / logs ─────────────────────────────────
*.log
.DS_Store
Thumbs.db
