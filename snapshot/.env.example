# Copy to .env (or export inline). Real keys go in .env, which is git-ignored.

# Alchemy API key only (not the full RPC URL). https://dashboard.alchemy.com
# Used for collection images + holder snapshot.
ALCHEMY_API_KEY=your_alchemy_key_here

# OpenSea API key. https://docs.opensea.io/reference/api-keys
# Used to pull the top trending + featured collections.
OPENSEA_API_KEY=your_opensea_key_here

# Optional overrides
# TRENDING_COUNT=20
# FEATURED_COUNT=20
# OPENSEA_TRENDING_ORDER=seven_day_volume
# OPENSEA_FEATURED_ORDER=market_cap
