# ───────────────────────────────────────────────────────────
# ROBARK.IO — web environment.
# Local: copy to .env.local. Production (Railway): set these in the
# service "Variables" tab. Only NEXT_PUBLIC_* are needed in production —
# the checker reads the bundled snapshot, so NO runtime API keys are required.
# ───────────────────────────────────────────────────────────

# Mint start (ISO 8601, UTC). Drives the homepage countdown.
NEXT_PUBLIC_MINT_START=2026-06-29T09:00:00Z

# Public site URL (no trailing slash). Used for share links + OG metadata.
# Set to your Railway URL or custom domain in production.
NEXT_PUBLIC_SITE_URL=https://robark.io

# ── Optional ──────────────────────────────────────────────
# Mint contract (leave unset until deployed).
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
# NEXT_PUBLIC_CHAIN_ID=1

# Alchemy key — NOT needed by the website at runtime anymore.
# Only used by the offline snapshot scripts in /snapshot.
# ALCHEMY_API_KEY=your_alchemy_key_here
